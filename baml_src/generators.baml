// TypeScript client generator (T-002-01). `output_dir "../"` is relative to baml_src/,
// so the client lands at the repo root: `baml_client/` (gitignored — a build product,
// regenerated by `bun run baml:gen`, never committed). version pins the installed
// baml-cli (0.223.0); a mismatch makes `baml-cli generate` refuse.
generator typescript {
  output_type "typescript"
  output_dir "../"
  version "0.223.0"
}
