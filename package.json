{
  "name": "vend",
  "version": "0.4.0-rc.7",
  "type": "module",
  "bin": {
    "vend": "./src/cli.ts"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "check:test": "bun test",
    "check:typecheck": "tsc --noEmit",
    "check:committed": "bun run src/ci/check-committed.ts",
    "check:presweep": "bun run src/ci/check-presweep.ts",
    "forward:promote": "bun run src/ledger/promote-forward.ts",
    "check:head": "bun run src/ci/check-head.ts",
    "check:history": "bun run src/ci/check-history.ts",
    "check:precommit": "bun run src/ci/check-precommit.ts",
    "check:hooks": "bun run src/ci/check-hooks.ts",
    "hooks:install": "bun run src/ci/install-hooks.ts",
    "baml:gen": "baml-cli generate --from baml_src",
    "check": "bun run baml:gen && bun run check:typecheck && bun run check:test",
    "build": "tsc --noEmit",
    "compile": "bun run src/release/compile.ts",
    "package": "bun run src/release/package.ts",
    "formula": "bun run src/release/formula.ts",
    "acceptance": "bun run src/release/acceptance.ts",
    "release:publish": "bun run src/release/publish.ts"
  },
  "dependencies": {
    "@boundaryml/baml": "^0.223.0",
    "envinfo": "^7.21.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^7.0.2"
  }
}
