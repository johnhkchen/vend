# vend release target — pinned by T-062-01 (E-061 / S-062).
#
# SINGLE SOURCE OF TRUTH for vend's first compiled binary target.
# T-062-02 (compile-self-contained-binary) and T-062-03 (release-ci-tarball-sha)
# read THIS file; they must reference keys by name, not hard-code the literals.
#
# MVP ships ONE platform first — the cook/dev's own machine (arm64-mac, Apple
# Silicon). The full 4-target matrix is OUT OF SCOPE (BAML native-addon
# cross-compile risk; ~108 MB binary). Add others in a later epic by appending,
# without invalidating this pin.
#
# Two naming schemes coexist (see docs/active/work/T-062-01/research.md):
#   BUN_COMPILE_TARGET   -> the string passed to `bun build --compile --target=...`
#   RELEASE_ASSET_TRIPLE -> the Rust/LLVM triple used in the tarball name, mirroring
#                           lisa's `lisa-cli-<arch>-<os>.tar.xz` convention.

BUN_COMPILE_TARGET=bun-darwin-arm64
RELEASE_ASSET_TRIPLE=aarch64-apple-darwin
RELEASE_TARBALL_PREFIX=vend-cli
RELEASE_TARBALL=vend-cli-aarch64-apple-darwin.tar.xz
CI_RUNNER=macos-14
# 1.3.13 is the newest KNOWN-GOOD bun: 1.3.14 segfaults at process exit under the
# BAML native addon (bridge tests exit 133) — bisected 2026-07-10. Re-try on the next bun release.
BUN_VERSION=1.3.13
