# Vend environment — reference only. Real values live in Doppler (project: vend).
#   doppler setup && doppler run -- bun run check
# This file is committed and contains NO secrets. It documents the full surface.

# --- Executor: Claude Code (default) ---
# Name/path of the Claude Code CLI used as the default executor.
CLAUDE_CLI=claude
# The claude executor authenticates via Claude Code's own login (~/.claude),
# NOT a key here. On a new device: `claude login`.

# --- BAML (prompt render/parse) ---
# Only needed if BAML calls Anthropic directly. The bridges fall back to a
# render-only dummy, so tests and build need no real value.
ANTHROPIC_API_KEY=

# --- Optional: open-model runner (OpenAI-compatible executor) ---
VEND_OPENAI_API_KEY=
VEND_OPENAI_BASE_URL=
VEND_EXECUTOR_MODEL=

# --- Optional ---
VEND_ATTESTOR=
